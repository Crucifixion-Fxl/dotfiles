#!/usr/bin/env bash

set -euo pipefail

# 本机 SSH 入口。用法：`connect-remote-dev <ssh-host>`。
#
# 设计意图：
#   1. 每次连接都使用本机 dotfiles 中最新的 remote-dev-entry。
#   2. 在同一条 SSH 连接内原子写入远程 ~/.local/bin，不需要额外 scp。
#   3. stdin 始终留给交互式菜单，因此脚本内容通过 Base64 嵌入远程命令。
#
# 此脚本不安装远程 tmux/zsh；要复现完整环境，仍应在远程运行 bootstrap。

fail() {
  printf 'connect-remote-dev：%s\n' "$*" >&2
  exit 1
}

run_ssh() {
  local host=$1 remote_command=$2
  exec ssh -t "$host" "$remote_command"
}

main() {
  local host script_dir entry payload remote_command

  [[ $# -eq 1 ]] || fail "用法：connect-remote-dev <ssh-host>"
  host=$1
  script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
  entry="$script_dir/remote-dev-entry"

  [[ -f "$entry" ]] || fail "找不到 $entry"
  command -v base64 >/dev/null 2>&1 || fail "本机未安装 base64"
  command -v ssh >/dev/null 2>&1 || fail "本机未安装 ssh"

  # Base64 避免脚本内容被本地/远程 shell 二次解析，并让 stdin 保持连接 TTY。
  # 远程先写临时文件再 mv，连接中断时不会留下半个入口脚本。
  payload=$(base64 < "$entry" | tr -d '\r\n')
  remote_command='set -eu
command -v base64 >/dev/null 2>&1 || {
  printf "%s\n" "connect-remote-dev：远端未安装 base64" >&2
  exit 127
}
directory="$HOME/.local/bin"
temporary="$directory/.remote-dev-entry.$$"
payload='"'$payload'"'
umask 077
mkdir -p "$directory"
trap '\''rm -f "$temporary"'\'' 0 HUP INT TERM
printf "%s" "$payload" | base64 -d > "$temporary"
chmod 700 "$temporary"
mv -f "$temporary" "$directory/remote-dev-entry"
trap - 0 HUP INT TERM
PATH="$directory:$PATH"
export PATH
exec "$directory/remote-dev-entry"'

  run_ssh "$host" "$remote_command"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
