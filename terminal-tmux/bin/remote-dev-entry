#!/usr/bin/env bash

set -euo pipefail

# 远程交互入口：先选择宿主机还是 Docker，再进入对应环境的 tmux。
#
# 核心约束：
#   - 宿主机分支直接 exec 宿主机 tmux。
#   - 容器分支直接 exec docker exec，tmux 只在容器内启动。
#   - 两个分支都不保留外层 shell/宿主机 tmux，避免多层 tmux 嵌套。
#   - 所有交互界面都监听 WINCH，终端缩放后会清屏并重新居中。

# 可在运行脚本前通过环境变量改名，默认两边都使用 dev。
HOST_TMUX_SESSION=${HOST_TMUX_SESSION:-dev}
CONTAINER_TMUX_SESSION=${CONTAINER_TMUX_SESSION:-dev}

fail() {
  printf 'remote-dev-entry：%s\n' "$*" >&2
  exit 1
}

enter_host_tmux() {
  # exec 会让 tmux 取代入口脚本，SSH 退出时不留额外进程。
  command -v tmux >/dev/null 2>&1 || fail "宿主机未安装 tmux"
  exec tmux new-session -A -s "$HOST_TMUX_SESSION"
}

enter_container_tmux() {
  local container_id=$1 container_name=$2
  local -a docker_environment

  printf '正在进入容器 %s（tmux session: %s）\n' \
    "$container_name" "$CONTAINER_TMUX_SESSION"

  # 该路径绝不创建宿主机 tmux。docker exec 取代 SSH 入口进程，后续 tmux
  # 命令只会在容器内解析和启动。TERM_PROGRAM 用于让 Yazi 识别 iTerm2 的
  # 图像协议；非受管入口未提供该变量时不向容器注入空值。
  docker_environment=(-e "TERM=${TERM:-xterm-256color}")
  if [[ -n ${TERM_PROGRAM:-} ]]; then
    docker_environment+=(-e "TERM_PROGRAM=$TERM_PROGRAM")
  fi
  exec docker exec -it "${docker_environment[@]}" "$container_id" sh -lc '
    export PATH="$HOME/.local/bin:$PATH"
    tmux_session=$1

    utf8_locale=
    if command -v locale >/dev/null 2>&1; then
      utf8_locale=$(locale -a 2>/dev/null | grep -Eim1 "^zh_CN\\.utf-?8$" || true)
      if [ -z "$utf8_locale" ]; then
        utf8_locale=$(locale -a 2>/dev/null | grep -Eim1 "^C\\.utf-?8$" || true)
      fi
    fi
    if [ -n "$utf8_locale" ]; then
      export LANG="$utf8_locale"
      export LC_ALL="$utf8_locale"
    else
      printf "%s\n" "remote-dev-entry：容器内没有可用的 UTF-8 locale，中文可能显示异常" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
    fi

    if ! command -v tmux >/dev/null 2>&1; then
      printf "%s\n" "remote-dev-entry：容器内未安装 tmux" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
      exit 127
    fi
    if ! command -v zsh >/dev/null 2>&1; then
      printf "%s\n" "remote-dev-entry：容器内未安装 zsh" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
      exit 127
    fi
    if [ ! -r "$HOME/.tmux.conf" ]; then
      printf "%s\n" "remote-dev-entry：找不到 $HOME/.tmux.conf" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
      exit 127
    fi

    # 已运行的 tmux server 会保留启动时的环境，因此附加前需要同步
    # locale，并重新加载受管配置。
    if [ -n "$utf8_locale" ]; then
      tmux set-environment -g LANG "$LANG" 2>/dev/null || true
      tmux set-environment -g LC_ALL "$LC_ALL" 2>/dev/null || true
    fi
    if tmux list-sessions >/dev/null 2>&1; then
      tmux source-file "$HOME/.tmux.conf" || {
        printf "%s\n" "remote-dev-entry：无法重新加载 $HOME/.tmux.conf" >&2
        exit 1
      }
    fi

    # 持久 session 可能正指向一个运行 bash/其他前台命令的 pane。新客户端优先选择
    # 空闲 zsh pane；只在没有空闲 zsh 时新建 window，永不终止已有进程。
    if tmux has-session -t "=$tmux_session" 2>/dev/null; then
      zsh_pane=
      attempt=0
      while [ "$attempt" -lt 10 ] && [ -z "$zsh_pane" ]; do
        set -- $(tmux list-panes -s -t "=$tmux_session" \
          -F "#{pane_id} #{pane_current_command}")
        while [ "$#" -ge 2 ]; do
          pane_id=$1
          pane_command=$2
          shift 2
          if [ "$pane_command" = zsh ]; then
            zsh_pane=$pane_id
            break
          fi
        done
        attempt=$((attempt + 1))
        [ -n "$zsh_pane" ] || sleep 0.05
      done
      if [ -z "$zsh_pane" ]; then
        zsh_pane=$(tmux new-window -d -P -F "#{pane_id}" -t "$tmux_session:" -n shell \
          "$HOME/.local/bin/tmux-zsh")
      fi
      zsh_window=$(tmux display-message -p -t "$zsh_pane" "#{window_id}")
      tmux select-window -t "$zsh_window"
      tmux select-pane -t "$zsh_pane"
    fi

    # 与手动进入流程保持一致：先加载 interactive login zsh，再显式使用
    # ~/.tmux.conf 创建/附加 session。
    exec zsh -lic '\''exec tmux -f "$HOME/.tmux.conf" new-session -A -s "$1"'\'' zsh "$tmux_session"
  ' sh "$CONTAINER_TMUX_SESSION"
}

terminal_size() {
  # 优先从 stty 读取实际 TTY 尺寸，tput/LINES/COLUMNS 只是兼容回退。
  local size lines columns

  size=$(stty size 2>/dev/null || true)
  if [[ "$size" =~ ^([1-9][0-9]*)[[:space:]]+([1-9][0-9]*)$ ]]; then
    lines=${BASH_REMATCH[1]}
    columns=${BASH_REMATCH[2]}
  else
    lines=$(tput lines 2>/dev/null || true)
    columns=$(tput cols 2>/dev/null || true)
  fi
  [[ "$lines" =~ ^[1-9][0-9]*$ ]] || lines=${LINES:-24}
  [[ "$columns" =~ ^[1-9][0-9]*$ ]] || columns=${COLUMNS:-80}
  [[ "$lines" =~ ^[1-9][0-9]*$ ]] || lines=24
  [[ "$columns" =~ ^[1-9][0-9]*$ ]] || columns=80

  printf '%d %d\n' "$lines" "$columns"
}

choose_container() {
  # 菜单每次外层循环都重新读取 docker ps；内层循环处理翻页、键盘和缩放。
  # REMOTE_DEV_MENU_ROWS 可改每页目标行数，实际行数仍会受终端高度限制。
  local container_output id name image status key key_tail index selected
  local interactive menu_resized read_status
  local configured_page_size page_size page_start page_end available_rows
  local terminal_lines terminal_columns menu_width menu_height menu_row menu_column
  local field_width name_width image_width status_width menu_text render_row
  local -a container_ids=()
  local -a container_names=()
  local -a container_images=()
  local -a container_statuses=()
  local -a menu_lines=()

  command -v docker >/dev/null 2>&1 || fail "宿主机未安装 Docker"
  selected=0
  interactive=0
  menu_resized=0
  if [[ -t 0 && -t 1 ]]; then
    interactive=1
    trap 'menu_resized=1' WINCH
  fi
  configured_page_size=${REMOTE_DEV_MENU_ROWS:-12}
  [[ "$configured_page_size" =~ ^[1-9][0-9]*$ ]] || configured_page_size=12
  while true; do
    container_ids=()
    container_names=()
    container_images=()
    container_statuses=()

    if ! container_output=$(docker ps --format '{{.ID}}\t{{.Names}}\t{{.Image}}\t{{.Status}}'); then
      fail "无法列出 Docker 容器，请检查 Docker daemon 和当前用户权限"
    fi

    while IFS=$'\t' read -r id name image status; do
      [[ -n "$id" ]] || continue
      container_ids+=("$id")
      container_names+=("$name")
      container_images+=("$image")
      container_statuses+=("$status")
    done <<< "$container_output"

    if (( ${#container_ids[@]} == 0 )); then
      if (( interactive )); then
        trap - WINCH
        printf '\033[2J\033[H'
      fi
      printf '%s\n' '没有正在运行的容器，将进入宿主机 tmux。'
      enter_host_tmux
      return
    fi

    (( selected < ${#container_ids[@]} )) || selected=0

    while true; do
      menu_resized=0
      page_size=$configured_page_size
      terminal_lines=24
      terminal_columns=80
      if (( interactive )); then
        read -r terminal_lines terminal_columns <<< "$(terminal_size)"
        available_rows=$((terminal_lines - 3))
        (( available_rows > 0 )) || available_rows=1
        (( page_size <= available_rows )) || page_size=$available_rows
      fi
      menu_width=88
      name_width=24
      image_width=32
      status_width=24
      if (( interactive && terminal_columns < menu_width )); then
        menu_width=$terminal_columns
        field_width=$((menu_width - 8))
        (( field_width >= 3 )) || field_width=3
        name_width=$((field_width * 3 / 10))
        image_width=$((field_width * 4 / 10))
        (( name_width > 0 )) || name_width=1
        (( image_width > 0 )) || image_width=1
        status_width=$((field_width - name_width - image_width))
        (( status_width > 0 )) || status_width=1
      fi

      page_start=$(( (selected / page_size) * page_size ))
      page_end=$((page_start + page_size))
      (( page_end <= ${#container_ids[@]} )) || page_end=${#container_ids[@]}

      menu_lines=()
      if (( interactive && terminal_columns < 60 )); then
        printf -v menu_text 'Docker 容器 %d（%d-%d）' \
          "${#container_ids[@]}" "$((page_start + 1))" "$page_end"
      else
        printf -v menu_text 'Docker 容器（%d 个正在运行，显示 %d-%d）' \
          "${#container_ids[@]}" "$((page_start + 1))" "$page_end"
      fi
      menu_lines+=("$menu_text")
      if (( interactive && terminal_columns < 60 )); then
        menu_lines+=('↑/↓ Enter进入 h宿主机 q退出')
      else
        menu_lines+=('↑/↓ 选择  Enter 进入  r 刷新  h 宿主机  q 退出')
      fi
      printf -v menu_text '  %-3s %-*.*s %-*.*s %-*.*s' '' \
        "$name_width" "$name_width" 'NAME' \
        "$image_width" "$image_width" 'IMAGE' \
        "$status_width" "$status_width" 'STATUS'
      menu_lines+=("$menu_text")

      for ((index = page_start; index < page_end; index++)); do
        if (( index == selected )); then
          if (( interactive )) && [[ ${TERM:-dumb} != dumb ]]; then
            printf -v menu_text '\033[7m  %-3s %-*.*s %-*.*s %-*.*s\033[0m' '>' \
              "$name_width" "$name_width" "${container_names[$index]}" \
              "$image_width" "$image_width" "${container_images[$index]}" \
              "$status_width" "$status_width" "${container_statuses[$index]}"
          else
            printf -v menu_text '  %-3s %-*.*s %-*.*s %-*.*s' '>' \
              "$name_width" "$name_width" "${container_names[$index]}" \
              "$image_width" "$image_width" "${container_images[$index]}" \
              "$status_width" "$status_width" "${container_statuses[$index]}"
          fi
        else
          printf -v menu_text '  %-3s %-*.*s %-*.*s %-*.*s' '' \
            "$name_width" "$name_width" "${container_names[$index]}" \
            "$image_width" "$image_width" "${container_images[$index]}" \
            "$status_width" "$status_width" "${container_statuses[$index]}"
        fi
        menu_lines+=("$menu_text")
      done

      if (( interactive )); then
        # 菜单最宽 88 列，窄终端会按比例压缩字段。先计算整个菜单块的居中原点，
        # 再绝对定位每一行；每次缩放先清屏，不会沿用旧尺寸的锚点。
        menu_height=${#menu_lines[@]}
        menu_row=$(((terminal_lines - menu_height) / 2 + 1))
        menu_column=$(((terminal_columns - menu_width) / 2 + 1))
        (( menu_row > 0 )) || menu_row=1
        (( menu_column > 0 )) || menu_column=1
        printf '\033[2J\033[H'
        render_row=$menu_row
        for menu_text in "${menu_lines[@]}"; do
          printf '\033[%d;%dH%s\033[K' "$render_row" "$menu_column" "$menu_text"
          render_row=$((render_row + 1))
        done
      else
        printf '%s\n' "${menu_lines[@]}"
      fi

      while true; do
        key=
        read_status=0
        if (( interactive )); then
          # macOS 自带 Bash 3.2，read 只接受整数超时。每秒轮询一次，使 WINCH
          # 设置的重绘标志能快速生效。
          IFS= read -rsn1 -t 1 key || read_status=$?
        else
          IFS= read -rsn1 key || read_status=$?
        fi
        (( menu_resized )) && break
        if (( read_status != 0 && interactive )); then
          continue
        fi
        (( read_status == 0 )) || key=q
        break
      done
      if (( menu_resized )); then
        continue
      fi
      case "$key" in
        '')
          if (( interactive )); then
            trap - WINCH
            printf '\033[2J\033[H'
          fi
          enter_container_tmux "${container_ids[$selected]}" "${container_names[$selected]}"
          return
          ;;
        $'\033')
          key_tail=
          IFS= read -rsn2 -t 1 key_tail || true
          case "$key_tail" in
            '[A') selected=$(( (selected - 1 + ${#container_ids[@]}) % ${#container_ids[@]} )) ;;
            '[B') selected=$(( (selected + 1) % ${#container_ids[@]} )) ;;
          esac
          ;;
        k|K)
          selected=$(( (selected - 1 + ${#container_ids[@]}) % ${#container_ids[@]} ))
          ;;
        j|J)
          selected=$(( (selected + 1) % ${#container_ids[@]} ))
          ;;
        r|R)
          break
          ;;
        h|H)
          if (( interactive )); then
            trap - WINCH
            printf '\033[2J\033[H'
          fi
          enter_host_tmux
          return
          ;;
        q|Q)
          if (( interactive )); then
            trap - WINCH
            printf '\033[2J\033[H'
          fi
          return 0
          ;;
      esac
    done
  done
}

render_docker_prompt() {
  # 初始询问界面只有两行，根据每次重绘时的 TTY 大小动态居中。
  local lines columns title hint title_row hint_row title_column hint_column

  title='是否进入 Docker 容器？'
  hint='Enter：进入    Esc：进入宿主机'
  read -r lines columns <<< "$(terminal_size)"

  title_row=$((lines / 2))
  (( title_row > 0 )) || title_row=1
  hint_row=$((title_row + 2))
  (( hint_row <= lines )) || hint_row=$lines

  # 这里使用的是终端显示宽度而非字符数：中文字符占两列。
  title_column=$(((columns - 22) / 2 + 1))
  hint_column=$(((columns - 30) / 2 + 1))
  (( title_column > 0 )) || title_column=1
  (( hint_column > 0 )) || hint_column=1

  printf '\033[2J\033[H'
  printf '\033[%d;%dH%s' "$title_row" "$title_column" "$title"
  printf '\033[%d;%dH%s' "$hint_row" "$hint_column" "$hint"
}

read_docker_choice() {
  # 交互 TTY 中 Enter 进容器菜单、Esc 进宿主机；非交互输入结束时安全回退宿主机。
  local answer read_status interactive prompt_resized

  DOCKER_CHOICE=host
  interactive=0
  prompt_resized=0
  if [[ -t 0 && -t 1 ]]; then
    interactive=1
    prompt_resized=1
    trap 'prompt_resized=1' WINCH
  else
    printf '%s' '是否进入 Docker 容器？Enter：进入  Esc：进入宿主机 '
  fi

  while true; do
    if (( prompt_resized )); then
      render_docker_prompt
      prompt_resized=0
    fi
    answer=
    read_status=0
    if (( interactive )); then
      IFS= read -rsn1 -t 1 answer || read_status=$?
    else
      IFS= read -rsn1 answer || read_status=$?
    fi
    if (( read_status == 0 )); then
      case "$answer" in
        '')
          DOCKER_CHOICE=container
          break
          ;;
        $'\033')
          DOCKER_CHOICE=host
          break
          ;;
        *)
          (( interactive == 0 )) || printf '\a'
          ;;
      esac
    else
      if (( interactive )); then
        continue
      fi
      DOCKER_CHOICE=host
      break
    fi
  done

  if (( interactive )); then
    trap - WINCH
    printf '\033[2J\033[H'
  fi
}

main() {
  read_docker_choice

  case "$DOCKER_CHOICE" in
    container)
      choose_container
      ;;
    *)
      enter_host_tmux
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
