#!/usr/bin/env bash

set -euo pipefail

HOST_TMUX_SESSION=${HOST_TMUX_SESSION:-dev}
CONTAINER_TMUX_SESSION=${CONTAINER_TMUX_SESSION:-dev}

fail() {
  printf 'remote-dev-entry：%s\n' "$*" >&2
  exit 1
}

enter_host_tmux() {
  command -v tmux >/dev/null 2>&1 || fail "宿主机未安装 tmux"
  exec tmux new-session -A -s "$HOST_TMUX_SESSION"
}

enter_container_tmux() {
  local container_id=$1 container_name=$2

  printf '正在进入容器 %s（tmux session: %s）\n' \
    "$container_name" "$CONTAINER_TMUX_SESSION"

  # No host tmux is created on this path. docker exec becomes the SSH session,
  # and the tmux command below is resolved and started inside the container.
  exec docker exec -it -e "TERM=${TERM:-xterm-256color}" "$container_id" sh -lc '
    export PATH="$HOME/.local/bin:$PATH"
    tmux_session=$1

    utf8_locale=
    if command -v locale >/dev/null 2>&1; then
      utf8_locale=$(locale -a 2>/dev/null | grep -Eim1 "^zh_CN\\.utf-?8$" || true)
      if [ -z "$utf8_locale" ]; then
        utf8_locale=$(locale -a 2>/dev/null | grep -Eim1 "^C\\.utf-?8$" || true)
      fi
    fi
    if [ -n "$utf8_locale" ]; then
      export LANG="$utf8_locale"
      export LC_ALL="$utf8_locale"
    else
      printf "%s\n" "remote-dev-entry：容器内没有可用的 UTF-8 locale，中文可能显示异常" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
    fi

    if ! command -v tmux >/dev/null 2>&1; then
      printf "%s\n" "remote-dev-entry：容器内未安装 tmux" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
      exit 127
    fi
    if ! command -v zsh >/dev/null 2>&1; then
      printf "%s\n" "remote-dev-entry：容器内未安装 zsh" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
      exit 127
    fi
    if [ ! -r "$HOME/.tmux.conf" ]; then
      printf "%s\n" "remote-dev-entry：找不到 $HOME/.tmux.conf" >&2
      printf "%s\n" "请先在容器内运行 dotfiles bootstrap。" >&2
      exit 127
    fi

    # An existing tmux server keeps the environment from when it was started.
    # Refresh its environment and reload the managed config before attaching.
    if [ -n "$utf8_locale" ]; then
      tmux set-environment -g LANG "$LANG" 2>/dev/null || true
      tmux set-environment -g LC_ALL "$LC_ALL" 2>/dev/null || true
    fi
    if tmux list-sessions >/dev/null 2>&1; then
      tmux source-file "$HOME/.tmux.conf" || {
        printf "%s\n" "remote-dev-entry：无法重新加载 $HOME/.tmux.conf" >&2
        exit 1
      }
    fi

    # A persistent session may currently point at a pane running bash or
    # another foreground command. Prefer an idle zsh pane for this new client;
    # create one only when the session has no idle zsh pane. Existing panes and
    # their processes are never terminated.
    if tmux has-session -t "=$tmux_session" 2>/dev/null; then
      zsh_pane=
      attempt=0
      while [ "$attempt" -lt 10 ] && [ -z "$zsh_pane" ]; do
        set -- $(tmux list-panes -s -t "=$tmux_session" \
          -F "#{pane_id} #{pane_current_command}")
        while [ "$#" -ge 2 ]; do
          pane_id=$1
          pane_command=$2
          shift 2
          if [ "$pane_command" = zsh ]; then
            zsh_pane=$pane_id
            break
          fi
        done
        attempt=$((attempt + 1))
        [ -n "$zsh_pane" ] || sleep 0.05
      done
      if [ -z "$zsh_pane" ]; then
        zsh_pane=$(tmux new-window -d -P -F "#{pane_id}" -t "$tmux_session:" -n shell \
          "$HOME/.local/bin/tmux-zsh")
      fi
      zsh_window=$(tmux display-message -p -t "$zsh_pane" "#{window_id}")
      tmux select-window -t "$zsh_window"
      tmux select-pane -t "$zsh_pane"
    fi

    # Match the working manual flow: load the interactive login zsh config,
    # then start tmux with an explicit config path when no server exists yet.
    exec zsh -lic '\''exec tmux -f "$HOME/.tmux.conf" new-session -A -s "$1"'\'' zsh "$tmux_session"
  ' sh "$CONTAINER_TMUX_SESSION"
}

choose_container() {
  local container_output id name image status key key_tail index selected menu_cursor_saved
  local page_size page_start page_end
  local -a container_ids=()
  local -a container_names=()
  local -a container_images=()
  local -a container_statuses=()

  command -v docker >/dev/null 2>&1 || fail "宿主机未安装 Docker"
  selected=0
  menu_cursor_saved=0
  page_size=${REMOTE_DEV_MENU_ROWS:-12}
  [[ "$page_size" =~ ^[1-9][0-9]*$ ]] || page_size=12
  while true; do
    container_ids=()
    container_names=()
    container_images=()
    container_statuses=()

    if ! container_output=$(docker ps --format '{{.ID}}\t{{.Names}}\t{{.Image}}\t{{.Status}}'); then
      fail "无法列出 Docker 容器，请检查 Docker daemon 和当前用户权限"
    fi

    while IFS=$'\t' read -r id name image status; do
      [[ -n "$id" ]] || continue
      container_ids+=("$id")
      container_names+=("$name")
      container_images+=("$image")
      container_statuses+=("$status")
    done <<< "$container_output"

    if (( ${#container_ids[@]} == 0 )); then
      if (( menu_cursor_saved )) && [[ -t 1 ]]; then
        printf '\0338\033[J'
        menu_cursor_saved=0
      fi
      printf '%s\n' '没有正在运行的容器，将进入宿主机 tmux。'
      enter_host_tmux
      return
    fi

    (( selected < ${#container_ids[@]} )) || selected=0

    while true; do
      page_start=$(( (selected / page_size) * page_size ))
      page_end=$((page_start + page_size))
      (( page_end <= ${#container_ids[@]} )) || page_end=${#container_ids[@]}

      # Restore the cursor to the beginning of the menu before clearing it.
      # Counting printed lines is unreliable because long table rows can wrap
      # to multiple terminal lines.
      if [[ -t 1 ]]; then
        if (( menu_cursor_saved )); then
          printf '\0338\033[J'
        else
          printf '\0337'
          menu_cursor_saved=1
        fi
      fi

      printf 'Docker 容器（%d 个正在运行，显示 %d-%d）\n' \
        "${#container_ids[@]}" "$((page_start + 1))" "$page_end"
      printf '%s\n' '↑/↓ 选择  Enter 进入  r 刷新  h 宿主机  q 退出'
      printf '  %-3s %-24s %-32s %s\n' '' 'NAME' 'IMAGE' 'STATUS'

      for ((index = page_start; index < page_end; index++)); do
        if (( index == selected )); then
          if [[ -t 1 && ${TERM:-dumb} != dumb ]]; then
            printf '\033[7m  %-3s %-24.24s %-32.32s %.24s\033[0m\n' \
              '>' "${container_names[$index]}" "${container_images[$index]}" "${container_statuses[$index]}"
          else
            printf '  %-3s %-24.24s %-32.32s %.24s\n' \
              '>' "${container_names[$index]}" "${container_images[$index]}" "${container_statuses[$index]}"
          fi
        else
          printf '  %-3s %-24.24s %-32.32s %.24s\n' \
            '' "${container_names[$index]}" "${container_images[$index]}" "${container_statuses[$index]}"
        fi
      done
      key=
      IFS= read -rsn1 key || key=q
      case "$key" in
        '')
          if (( menu_cursor_saved )) && [[ -t 1 ]]; then
            printf '\0338\033[J'
            menu_cursor_saved=0
          fi
          enter_container_tmux "${container_ids[$selected]}" "${container_names[$selected]}"
          return
          ;;
        $'\033')
          key_tail=
          IFS= read -rsn2 -t 1 key_tail || true
          case "$key_tail" in
            '[A') selected=$(( (selected - 1 + ${#container_ids[@]}) % ${#container_ids[@]} )) ;;
            '[B') selected=$(( (selected + 1) % ${#container_ids[@]} )) ;;
          esac
          ;;
        k|K)
          selected=$(( (selected - 1 + ${#container_ids[@]}) % ${#container_ids[@]} ))
          ;;
        j|J)
          selected=$(( (selected + 1) % ${#container_ids[@]} ))
          ;;
        r|R)
          break
          ;;
        h|H)
          if (( menu_cursor_saved )) && [[ -t 1 ]]; then
            printf '\0338\033[J'
            menu_cursor_saved=0
          fi
          enter_host_tmux
          return
          ;;
        q|Q)
          if (( menu_cursor_saved )) && [[ -t 1 ]]; then
            printf '\0338\033[J'
            menu_cursor_saved=0
          fi
          return 0
          ;;
      esac
    done
  done
}

render_docker_prompt() {
  local lines columns title hint title_row hint_row title_column hint_column

  title='是否进入 Docker 容器？'
  hint='Enter：进入    Esc：进入宿主机'
  lines=$(tput lines 2>/dev/null || true)
  columns=$(tput cols 2>/dev/null || true)
  [[ "$lines" =~ ^[1-9][0-9]*$ ]] || lines=${LINES:-24}
  [[ "$columns" =~ ^[1-9][0-9]*$ ]] || columns=${COLUMNS:-80}
  [[ "$lines" =~ ^[1-9][0-9]*$ ]] || lines=24
  [[ "$columns" =~ ^[1-9][0-9]*$ ]] || columns=80

  title_row=$((lines / 2))
  (( title_row > 0 )) || title_row=1
  hint_row=$((title_row + 2))
  (( hint_row <= lines )) || hint_row=$lines

  # Display widths: title=22, hint=30. Chinese characters occupy two columns.
  title_column=$(((columns - 22) / 2 + 1))
  hint_column=$(((columns - 30) / 2 + 1))
  (( title_column > 0 )) || title_column=1
  (( hint_column > 0 )) || hint_column=1

  printf '\033[2J\033[H'
  printf '\033[%d;%dH%s' "$title_row" "$title_column" "$title"
  printf '\033[%d;%dH%s' "$hint_row" "$hint_column" "$hint"
}

read_docker_choice() {
  local answer read_status interactive

  DOCKER_CHOICE=host
  interactive=0
  if [[ -t 0 && -t 1 ]]; then
    interactive=1
    trap 'render_docker_prompt' WINCH
    render_docker_prompt
  else
    printf '%s' '是否进入 Docker 容器？Enter：进入  Esc：进入宿主机 '
  fi

  while true; do
    answer=
    if IFS= read -rsn1 answer; then
      case "$answer" in
        '')
          DOCKER_CHOICE=container
          break
          ;;
        $'\033')
          DOCKER_CHOICE=host
          break
          ;;
        *)
          (( interactive == 0 )) || printf '\a'
          ;;
      esac
    else
      read_status=$?
      if (( interactive && read_status > 128 )); then
        continue
      fi
      DOCKER_CHOICE=host
      break
    fi
  done

  if (( interactive )); then
    trap - WINCH
    printf '\033[2J\033[H'
  fi
}

main() {
  read_docker_choice

  case "$DOCKER_CHOICE" in
    container)
      choose_container
      ;;
    *)
      enter_host_tmux
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
