#!/usr/bin/env bash

set -euo pipefail

# The official pre-commit zipapp requires Python 3.10+. Prefer versioned
# interpreters so macOS can use Homebrew Python even when /usr/bin/python3 is
# older and appears earlier in PATH.
PYZ=${PRE_COMMIT_PYZ:-"$HOME/.local/share/pre-commit/pre-commit.pyz"}

[[ -r "$PYZ" ]] || {
  printf 'pre-commit: managed zipapp is missing: %s\n' "$PYZ" >&2
  printf 'Run ~/.dotfiles/terminal-tmux/bootstrap.sh to install it.\n' >&2
  exit 1
}

find_supported_python() {
  local candidate
  for candidate in python3.14 python3.13 python3.12 python3.11 python3.10 python3; do
    if command -v "$candidate" >/dev/null 2>&1 &&
      "$candidate" -c 'import sys; raise SystemExit(sys.version_info < (3, 10))' 2>/dev/null; then
      command -v "$candidate"
      return 0
    fi
  done
  return 1
}

PYTHON=$(find_supported_python) || {
  printf '%s\n' 'pre-commit: Python 3.10 or newer is required.' >&2
  exit 1
}

exec "$PYTHON" "$PYZ" "$@"
