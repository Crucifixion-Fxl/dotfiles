# Keep user-local tools available in both interactive and login shells.
export PATH="$HOME/.local/bin:$PATH"
export LANG=zh_CN.UTF-8
export LC_ALL=zh_CN.UTF-8

# Oh My Zsh, theme, and plugins are installed at locked commits by bootstrap.sh.
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"

plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# Preserve the local Conda behavior without assuming the same home directory
# or requiring Conda on remote hosts.
if [[ -x "$HOME/miniconda3/bin/conda" ]]; then
  __conda_setup="$("$HOME/miniconda3/bin/conda" shell.zsh hook 2>/dev/null)"
  if [[ $? -eq 0 ]]; then
    eval "$__conda_setup"
  elif [[ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]]; then
    source "$HOME/miniconda3/etc/profile.d/conda.sh"
  else
    export PATH="$HOME/miniconda3/bin:$PATH"
  fi
  unset __conda_setup
fi

# Keep tmux window names aligned with the active command.
source "$HOME/.config/tmux/window-name.zsh"

# Launch Yazi and change this shell to Yazi's last directory on exit.
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	command rm -f -- "$tmp"
}

# Optional machine-only additions belong here and are intentionally untracked.
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
